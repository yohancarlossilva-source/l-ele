
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Estatístico do Agro Brasil</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

    <header>
        <h1>Painel de Estatísticas do Agronegócio Brasileiro</h1>
        <p>Dados integrados em tempo real via API Java</p>
    </header>

    <div class="container">
        <div class="grid-cards">
            <div class="card">
                <h3>Participação no PIB</h3>
                <p id="pib-card">...</p>
            </div>
            <div class="card">
                <h3>Exportações Anuais</h3>
                <p id="exp-card">...</p>
            </div>
        </div>

        <div class="dashboard-section">
            <h2>Produção de Grãos por Cultura (Milhões de Toneladas)</h2>
            <div class="chart-wrapper">
                <canvas id="graficoAgro"></canvas>
            </div>
        </div>
    </div>

    <script>
        // URL da API Java (Localhost padrão do Spring Boot)
        const API_URL = "http://localhost:8080/api/estatisticas";

        // Função que busca os dados do Java e monta a tela
        async function carregarDadosDoAgro() {
            try {
                // Faz a requisição para o servidor Java
                const resposta = await fetch(API_URL);
                const dados = await resposta.json();

                // Atualiza os textos dos cards com os dados vindos do Java
                document.getElementById('pib-card').innerText = `~ ${dados.pibParticipacao}`;
                document.getElementById('exp-card').innerText = `US$ ${dados.exportacoesBilhotoes} Bi`;

                // Configura e gera o gráfico com os dados recebidos
                const ctx = document.getElementById('graficoAgro').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: dados.culturas, // Legendas vindas do Java
                        datasets: [{
                            label: 'Produção (Milhões de T)',
                            data: dados.producao, // Valores vindos do Java
                            backgroundColor: [
                                '#2e7d32', '#689f38', '#8bc34a', '#aed581', '#c5e1a5'
                            ],
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });

            } catch (error) {
                console.error("Erro ao conectar com a API Java: ", error);
                alert("Não foi possível conectar ao servidor Java. Certifique-se de que o Back-end está rodando.");
            }
        }

        // Executa a função assim que a página carrega
        window.onload = carregarDadosDoAgro;
    </script>
</body>
</html>
