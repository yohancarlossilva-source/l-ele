<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Agro Brasil - Estatísticas</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <header>
    <h1>🌾 Estatísticas do Agronegócio Brasileiro</h1>
    <p>Dados simplificados da produção agrícola do Brasil</p>
  </header>

  <section class="cards">

    <div class="card">
      <h2>🌱 Soja</h2>
      <p id="soja">Carregando...</p>
    </div>

    <div class="card">
      <h2>🌽 Milho</h2>
      <p id="milho">Carregando...</p>
    </div>

    <div class="card">
      <h2>🌾 Produção Total</h2>
      <p id="total">Carregando...</p>
    </div>

  </section>

  <section class="chart">
    <h2>📊 Gráfico Simples</h2>
    <canvas id="grafico"></canvas>
  </section>

  <footer>
    <p>Dados ilustrativos baseados em estimativas do agro brasileiro</p>
  </footer>

  <script src="script.js"></script>
</body>
</html>
